# MongoDB Connection URI
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/auditai?retryWrites=true&w=majority

# JWT Secret for token generation
JWT_SECRET=your_super_secret_jwt_key_here

# Email Configuration (EmailJS)
EMAILJS_SERVICE_ID=service_12345
EMAILJS_PUBLIC_KEY=user_12345
EMAILJS_PRIVATE_KEY=your_private_key
EMAILJS_AUDIT_TEMPLATE_ID=audit_results
EMAILJS_RESET_TEMPLATE_ID=password_reset

# Frontend URL (for email links and CORS)
# For development:
# FRONTEND_URL=http://localhost:5173

# For production (Vercel):
FRONTEND_URL=https://audit-ai-nu.vercel.app

# Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Server Port
PORT=8080
