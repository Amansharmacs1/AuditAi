# MongoDB Connection URI
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/auditai?retryWrites=true&w=majority

# JWT Secret for token generation
JWT_SECRET=your_super_secret_jwt_key_here

# Email Configuration
# 1. Recommended: Resend (HTTP based, most reliable on Render)
RESEND_API_KEY=re_123456789

# 2. Fallback: Gmail (SMTP with App Password)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-specific-password

# Frontend URL (for email links and CORS)
# For development:
# FRONTEND_URL=http://localhost:5173

# For production (Vercel):
FRONTEND_URL=https://audit-ai-nu.vercel.app

# Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Server Port
PORT=8080
